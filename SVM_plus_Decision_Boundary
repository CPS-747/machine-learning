preprocessor),\n    ('pca', PCA(n_components=2))\n])\n\n# Extract 2D datasets\nX_train_2d = transform_pipeline.fit_transform(X_train)\nX_test_2d = transform_pipeline.transform(X_test)\n\n# Train a dedicated 2D SVM model\nviz_model = LinearSVC(C=0.08)\nviz_model.fit(X_train_2d, y_train_encoded)\n\n# Plotting\nfig, ax = plt.subplots(figsize=(10, 7))\n\n# Draw background boundaries\ndisp = DecisionBoundaryDisplay.from_estimator(\n    viz_model, \n    X=X_test_2d,\n    alpha=0.4,\n    ax=ax\n)\n\n# Overlay data points\nsns.scatterplot(\n    x=X_test_2d[:, 0], \n    y=X_test_2d[:, 1], \n    hue=encoder.inverse_transform(y_test_encoded), # Names back from encoder\n    palette='hsv',\n    edgecolor='k',\n    alpha=0.8,\n    ax=disp.ax_\n)\n\nplt.title(\"PCA Decision Boundary with Test Data Overlay\")\nplt.xlabel(\"Principal Component 1\")\nplt.ylabel(\"Principal Component 2\")\nplt.legend(bbox_to_anchor=(1.02, 1), loc='upper left', title=\"Species\") \nplt.tight_layout()\nplt.show()\n\n# CONFUSION MATRIX (Uses the original 8-feature model_pipeline) -------------------------------------------\n\nfig, ax = plt.subplots(figsize=(8, 6))\nConfusionMatrixDisplay.from_estimator(\n    model_pipeline, \n    X_test, \n    y_test_encoded,\n    display_labels=encoder.classes_, # Uses original species names\n    cmap='winter_r', \n    normalize='true',\n    ax=ax\n)\nplt.xticks(rotation=45)\nplt.title(\"Confusion Matrix (Normalized)\")\nplt.tight_layout()\nplt.show()\n\n# CLASSIFICATION REPORT ------------------------------------------------------------------------------\n\ny_pred = model_pipeline.predict(X_test)\nprint(\"Classification Report (8-Feature Model):\\n\")\nprint(classification_report(\n    y_test_encoded, \n    y_pred, \n    target_names=encoder.classes_\n))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-28T20:39:15.511479Z","iopub.execute_input":"2026-06-28T20:39:15.51176Z","iopub.status.idle":"2026-06-28T20:39:17.659665Z","shell.execute_reply.start